<!-- Reglas personalizadas para detección de Brute Force SSH -->
<group name="ssh,brute_force,custom">

  <!-- Regla base: captura intentos fallidos SSH -->
  <rule id="100001" level="5">
    <if_sid>5760</if_sid>
    <description>Intento de autenticación SSH fallido</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- Regla de correlación: 10+ fallos desde misma IP en 60 segundos -->
  <rule id="100002" level="10" frequency="10" timeframe="60">
    <if_matched_sid>100001</if_matched_sid>
    <same_source_ip />
    <description>ALERTA: Brute Force SSH detectado - 10+ intentos fallidos en 60 segundos desde la misma IP</description>
    <group>authentication_failures,brute_force</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

</group>
